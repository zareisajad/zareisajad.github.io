---
import Links from '../components/widgets/Links.astro';
---

<div class="h-screen grid gap-4 grid-cols-4 grid-rows-6 p-4">
    <!-- Links -->
    <div class="bg-white p-4 rounded-lg row-span-1 col-span-4"><Links /></div>

    <!-- Logs -->
    <div class="bg-white p-4 rounded-lg row-span-1 col-span-2">Logs: ...</div>

    <!-- Random text -->
    <div class="bg-white p-4 rounded-lg row-span-1 col-span-2">Random text...</div>

    <!-- Deepdives -->
    <div class="bg-white p-4 rounded-lg row-span-2 col-span-4">Deepdives - (learning)</div>

    <!-- Blog entries -->
